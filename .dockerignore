# ------------------------------------------------------------------------------
# Baseline `.dockerignore` for new Dockerised projects to keep the build context
# small and free of secrets and local state.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Project-specific ignores.
#
# Add project-specific patterns in this section.
# ------------------------------------------------------------------------------
.github/copilot-instructions.md
.git/
.gitignore
.shellcheckrc
*.md
AGENTS.md
CLAUDE.md
README.md
scratchpad.sh
test.sh
TODO.md

# ------------------------------------------------------------------------------
# Environment and secrets.
# ------------------------------------------------------------------------------
.env
.env.*.local
.env.local
secrets/

# ------------------------------------------------------------------------------
# Python artifacts.
# ------------------------------------------------------------------------------
.coverage
.coverage.*
.mypy_cache/
.pytest_cache/
.venv/
*.py[cod]
*.pyd
__pycache__/
venv/

# ------------------------------------------------------------------------------
# Node and frontend artifacts.
# ------------------------------------------------------------------------------
.next/
.nuxt/
.svelte-kit/
coverage/
node_modules/

# ------------------------------------------------------------------------------
# Runtime and compose files.
# ------------------------------------------------------------------------------
compose.yml
config/
data/
docker-compose.yml
logs/
output/

# ------------------------------------------------------------------------------
# IDE and operating system files.
# ------------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
