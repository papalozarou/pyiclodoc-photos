# ------------------------------------------------------------------------------
# This environment file defines non-secret Compose values used by local runs.
#
# Values are grouped by scope to keep host and container concerns separate.
# Host-scoped variables use "H_" and container-scoped variables use "C_".
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Image name
# ------------------------------------------------------------------------------
IMG_NAME=papalozarou/pyiclodoc-photos

# ------------------------------------------------------------------------------
# Software versions, listed in docker compose.yml order:
#
# - ALP_VER – Alpine version
# - MCK_VER – Microcheck version for healthcheck
# ------------------------------------------------------------------------------
ALP_VER=3.23.3
MCK_VER=1.3.0

# ------------------------------------------------------------------------------
# Host (H_[ARG]) environment information
# 
# N.B.
# The following must be set in your shell environment either manually, or as 
# part of your initial setup using the "linux-setup" scripts:
#
# - "$HOST_TIMEZONE"
# ------------------------------------------------------------------------------
H_TZ=Europe/London

# ------------------------------------------------------------------------------
# Host (H_[ARG]) USR and GRP information
# 
# N.B.
# "$SUDO_UID", "$SUDO_GID", and "$SUDO_USER" are global shell environment 
# variables
# ------------------------------------------------------------------------------
H_UID=$SUDO_UID
H_GID=$SUDO_GID

# ------------------------------------------------------------------------------
# Host (H_[ARG]) variables
# ------------------------------------------------------------------------------
# Data path
# --------------------------------------
H_DATA_PATH=./data/
# --------------------------------------
# Docker
# --------------------------------------
H_DKR_SECRETS=/var/lib/docker/secrets

# --------------------------------------
# Telegram
# --------------------------------------
H_TGM_CHAT_ID=123456789

# ------------------------------------------------------------------------------
# Runtime USR and GRP information
#
# N.B.
# To avoid permission errors, this matches the host information.
# ------------------------------------------------------------------------------
C_UID=${H_UID}
C_GID=${H_GID}

# ------------------------------------------------------------------------------
# Container (C_[ARG]) variables
#
# N.B.
# "C_RUN_USR_DIR", "C_RUN_UID_DIR" and "C_USR_DIR" are required to build the
# alpine base image.
# ------------------------------------------------------------------------------
# System directories
# --------------------------------------
C_RUN_DIR=/run

# --------------------------------------
# Docker
# --------------------------------------
C_DKR_SECRETS=${C_RUN_DIR}/secrets
C_LOG_LEVEL=info

# --------------------------------------
# Logs
# --------------------------------------
C_LOG_ROTATE_DAILY=true
C_LOG_ROTATE_MAX_MIB=100
C_LOG_ROTATE_KEEP_DAYS=14

# ------------------------------------------------------------------------------
# Define Alice service values.
#
# 1. The path values map Alice state to an isolated host directory.
# 2. The secret-file values point at Docker secret mounts inside the container.
# 3. The schedule values define when automatic backups run.
# 4. The backup values define album-output behaviour and delete handling.
#
# N.B.
# "ALICE_BACKUP_ALBUM_LINKS_MODE=hardlink" is the preferred default because it
# avoids duplicate data when the host filesystem allows hard links.
# "copy" disables hard links entirely and always creates separate album files.
# "ALICE_BACKUP_DISCOVERY_MODE=until_found" is only valid when delete handling
# and album management are both disabled.
# ------------------------------------------------------------------------------
ALICE_CONFIG_PATH=${H_DATA_PATH}/alice/config
ALICE_OUTPUT_PATH=${H_DATA_PATH}/alice/output
ALICE_LOGS_PATH=${H_DATA_PATH}/alice/logs

ALICE_ICLOUD_EMAIL_FILE=${C_DKR_SECRETS}/alice_icloud_email
ALICE_ICLOUD_PASSWORD_FILE=${C_DKR_SECRETS}/alice_icloud_password
ALICE_REAUTH_INTERVAL_DAYS=30

ALICE_RUN_ONCE=false

ALICE_SCHEDULE_MODE=interval
ALICE_SCHEDULE_BACKUP_TIME=02:00
ALICE_SCHEDULE_WEEKDAYS=monday
ALICE_SCHEDULE_MONTHLY_WEEK=first
ALICE_SCHEDULE_INTERVAL_MINUTES=1440

ALICE_SYNC_DOWNLOAD_WORKERS=auto
ALICE_SYNC_DOWNLOAD_CHUNK_MIB=4

ALICE_BACKUP_DISCOVERY_MODE=full
ALICE_BACKUP_UNTIL_FOUND_COUNT=50
ALICE_BACKUP_DELETE_REMOVED=false
ALICE_BACKUP_ALBUMS_ENABLED=true
ALICE_BACKUP_ALBUM_LINKS_MODE=hardlink
ALICE_BACKUP_INCLUDE_SHARED_ALBUMS=true
ALICE_BACKUP_INCLUDE_FAVOURITES=true

ALICE_RESTART_POLICY=unless-stopped
ALICE_TGM_BOT_TOKEN_FILE=${C_DKR_SECRETS}/telegram_bot_token

# ------------------------------------------------------------------------------
# Define Bob service values.
#
# 1. The Bob block mirrors the Alice block so the example remains predictable.
# 2. Each Bob value should point at Bob-specific host paths and secret files.
# 3. Schedule and backup values can diverge from Alice once real usage starts.
#
# N.B.
# "BOB_BACKUP_DISCOVERY_MODE=until_found" is only valid when delete handling
# and album management are both disabled.
# ------------------------------------------------------------------------------
BOB_CONFIG_PATH=${H_DATA_PATH}/bob/config
BOB_OUTPUT_PATH=${H_DATA_PATH}/bob/output
BOB_LOGS_PATH=${H_DATA_PATH}/bob/logs

BOB_ICLOUD_EMAIL_FILE=${C_DKR_SECRETS}/bob_icloud_email
BOB_ICLOUD_PASSWORD_FILE=${C_DKR_SECRETS}/bob_icloud_password
BOB_REAUTH_INTERVAL_DAYS=30

BOB_RUN_ONCE=false

BOB_SCHEDULE_MODE=interval
BOB_SCHEDULE_BACKUP_TIME=02:00
BOB_SCHEDULE_WEEKDAYS=monday
BOB_SCHEDULE_MONTHLY_WEEK=first
BOB_SCHEDULE_INTERVAL_MINUTES=1440

BOB_SYNC_DOWNLOAD_WORKERS=auto
BOB_SYNC_DOWNLOAD_CHUNK_MIB=4

BOB_BACKUP_DISCOVERY_MODE=full
BOB_BACKUP_UNTIL_FOUND_COUNT=50
BOB_BACKUP_DELETE_REMOVED=false
BOB_BACKUP_ALBUMS_ENABLED=true
BOB_BACKUP_ALBUM_LINKS_MODE=hardlink
BOB_BACKUP_INCLUDE_SHARED_ALBUMS=true
BOB_BACKUP_INCLUDE_FAVOURITES=true

BOB_RESTART_POLICY=unless-stopped
BOB_TGM_BOT_TOKEN_FILE=${C_DKR_SECRETS}/telegram_bot_token
