# ------------------------------------------------------------------------------
# This environment file defines non-secret Compose values used by local runs.
# ------------------------------------------------------------------------------

IMG_NAME=papalozarou/pyiclodoc-photos

ALP_VER=3.23.3
MCK_VER=1.3.0

H_TZ=Europe/London
H_DATA_PATH=./data
H_DKR_SECRETS=/var/lib/docker/secrets
H_TGM_CHAT_ID=123456789

C_UID=1000
C_GID=1000
C_LOG_LEVEL=info
C_LOG_ROTATE_DAILY=true
C_LOG_ROTATE_MAX_MIB=100
C_LOG_ROTATE_KEEP_DAYS=14

ALICE_CONFIG_PATH=${H_DATA_PATH}/alice/config
ALICE_OUTPUT_PATH=${H_DATA_PATH}/alice/output
ALICE_LOGS_PATH=${H_DATA_PATH}/alice/logs
ALICE_ICLOUD_EMAIL_FILE=/run/secrets/alice_icloud_email
ALICE_ICLOUD_PASSWORD_FILE=/run/secrets/alice_icloud_password
ALICE_REAUTH_INTERVAL_DAYS=30
ALICE_RUN_ONCE=false
ALICE_SCHEDULE_MODE=interval
ALICE_SCHEDULE_BACKUP_TIME=02:00
ALICE_SCHEDULE_WEEKDAYS=monday
ALICE_SCHEDULE_MONTHLY_WEEK=first
ALICE_SCHEDULE_INTERVAL_MINUTES=1440
ALICE_SYNC_TRAVERSAL_WORKERS=1
ALICE_SYNC_DOWNLOAD_WORKERS=auto
ALICE_SYNC_DOWNLOAD_CHUNK_MIB=4
ALICE_BACKUP_DELETE_REMOVED=false
ALICE_BACKUP_LIBRARY_ENABLED=true
ALICE_BACKUP_ALBUMS_ENABLED=true
ALICE_BACKUP_ALBUM_LINKS_MODE=hardlink
ALICE_BACKUP_INCLUDE_SHARED_ALBUMS=true
ALICE_BACKUP_INCLUDE_FAVOURITES=true
ALICE_RESTART_POLICY=unless-stopped
ALICE_TGM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token

BOB_CONFIG_PATH=${H_DATA_PATH}/bob/config
BOB_OUTPUT_PATH=${H_DATA_PATH}/bob/output
BOB_LOGS_PATH=${H_DATA_PATH}/bob/logs
BOB_ICLOUD_EMAIL_FILE=/run/secrets/bob_icloud_email
BOB_ICLOUD_PASSWORD_FILE=/run/secrets/bob_icloud_password
BOB_REAUTH_INTERVAL_DAYS=30
BOB_RUN_ONCE=false
BOB_SCHEDULE_MODE=interval
BOB_SCHEDULE_BACKUP_TIME=02:00
BOB_SCHEDULE_WEEKDAYS=monday
BOB_SCHEDULE_MONTHLY_WEEK=first
BOB_SCHEDULE_INTERVAL_MINUTES=1440
BOB_SYNC_TRAVERSAL_WORKERS=1
BOB_SYNC_DOWNLOAD_WORKERS=auto
BOB_SYNC_DOWNLOAD_CHUNK_MIB=4
BOB_BACKUP_DELETE_REMOVED=false
BOB_BACKUP_LIBRARY_ENABLED=true
BOB_BACKUP_ALBUMS_ENABLED=true
BOB_BACKUP_ALBUM_LINKS_MODE=hardlink
BOB_BACKUP_INCLUDE_SHARED_ALBUMS=true
BOB_BACKUP_INCLUDE_FAVOURITES=true
BOB_RESTART_POLICY=unless-stopped
BOB_TGM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
